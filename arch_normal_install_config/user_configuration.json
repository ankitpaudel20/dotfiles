    "plasma-disks",
    "plasma-integration",
    "plasma-nm",
    "plasma-pa",
    "plasma-systemmonitor",
    "plasma-wayland-session",
    "powertop",
    "psensors",
    "python",
    "python-pip",
    "qalculate-qt",
    "qbittorrent",
    "qemu-full",
    "reflector",
    "sddm",
    "sof-firmware",
    "spectacle",
    "spotify-launcher",
    "tlpui",
    "ttf-jetbrains-mono",
    "veracrypt",
    "vim",
    "wayland",
    "wget",
    "xorg",
    "yq",
    "zed",
    "zellij",
    "zsh",
    "zsh-autosuggestions",
    "zsh-completions",
    "zsh-syntax-highlighting",
    "zsh-theme-powerlevel10k"
