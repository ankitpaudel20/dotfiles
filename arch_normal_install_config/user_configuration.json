{
  "additional-repositories": [],
  "archinstall-language": "English",
  "audio_config": {
    "audio": "pipewire"
  },
  "bootloader": "Systemd-boot",
  "config_version": "2.6.3",
  "debug": false,
  "disk_encryption": null,
  "guided": true,
  "hostname": "archlinux",
  "kernels": ["linux", "linux-lts"],
  "locale_config": {
    "kb_layout": "us",
    "sys_enc": "UTF-8",
    "sys_lang": "en_US"
  },
  "network_config": {
    "type": "nm"
  },
  "no_pkg_lookups": false,
  "ntp": true,
  "offline": false,
  "packages": [
    "adb",
    "alacritty",
    "alsa-tools",
    "alsa-utils",
    "arch-install-scripts",
    "bat",
    "bluez-utils",
    "btop",
