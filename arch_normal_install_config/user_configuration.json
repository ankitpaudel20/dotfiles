    "docker",
    "docker-compose",
    "dolphin",
    "easyeffects",
    "eza",
    "fastfetch",
    "firefox",
    "flameshot",
    "git",
    "github-cli",
    "helm",
    "htop",
    "intel-gpu-tools",
    "intel-ucode",
    "inxi",
    "k9s",
    "kate",
    "kdeconnect",
    "khotkeys",
    "konsole",
    "krew",
    "kscreen",
    "lazydocker",
    "libreoffice-fresh",
    "localsend-bin",
    "mpv",
    "neofetch",
    "neovim",
    "noto-fonts",
    "noto-fonts-emoji",
