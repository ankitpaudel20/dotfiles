  "parallel downloads": 15,
  "profile_config": {
    "gfx_driver": null,
    "greeter": "sddm",
    "profile": {
      "custom_settings": {},
      "details": [],
      "main": "Minimal"
    }
  },
  "script": "guided",
  "silent": false,
  "swap": true,
  "timezone": "Asia/Kathmandu",
  "version": "2.6.3",
  "custom-commands": [
    "git clone https://aur.archlinux.org/yay.git && cd yay && makepkg -si --needed --noconfirm --asdeps",
    "usermod -aG docker,audio,video,storage,network smloy",
    "yay -S --noconfirm acer-wmi-battery-dkms android-sdk-platform-tools antigravity brave-bin cursor-bin helm-ls-bin localsend-bin opencode-bin  postman-bin qownnotes quickemu-git quickgui-bin",
    "sytemctl enable NetworkManager sddm"
  ]
}
